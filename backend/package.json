{
  "name": "manufacturing-erp-backend",
  "version": "1.0.0",
  "description": "Garment/Apparel ERP Manufacturing module API",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "node src/app.js",
    "dev": "node --watch src/app.js",
    "test:integration": "npm run test:next-employee-id && npm run test:account-settings && npm run test:account-settings-validation",
    "test:account-settings": "node tests/accountSettings.integration.test.js",
    "test:account-settings-validation": "node tests/accountSettings.validation.integration.test.js",
    "test:next-employee-id": "node tests/nextEmployeeId.integration.test.js",
    "seed": "node src/scripts/seed.js",
    "migrate": "node src/scripts/seed.js",
    "contract:check": "node src/scripts/contract-check.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "nodemailer": "^6.9.14"
  }
}
