PORT=5001
NODE_ENV=production

# MongoDB Atlas connection string for Render production.
# Replace the placeholders with your Atlas username, password, and cluster host.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/manufacturing_erp?retryWrites=true&w=majority

# Comma-separated list of allowed frontend origins.
# Add your Vercel URL here, plus localhost for development.
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Render sets PORT automatically, but keeping a local default is fine for development.
# JWT_SECRET should be a long, random string in production.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Optional external AI service URL.
AI_SERVICE_URL=http://localhost:8000
