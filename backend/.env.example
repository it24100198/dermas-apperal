PORT=5000
# Use 127.0.0.1 on Windows if localhost times out (IPv6 vs IPv4).
MONGODB_URI=mongodb://127.0.0.1:27017/manufacturing_erp

# If you use npm run db:up from this folder, Docker maps Mongo to host port 27018 by default
# (27017 is often already taken). Then set:
# MONGODB_URI=mongodb://127.0.0.1:27018/manufacturing_erp
# Optional: MONGO_HOST_PORT=27018 in .env (default) or 27017 if that port is free.
